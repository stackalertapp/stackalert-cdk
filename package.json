    "aws-cdk": "^2.1006.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.1006.0",
    "constructs": "^10.4.2"
  }
