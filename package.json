{
  "name": "stackalert-cdk",
  "version": "0.1.0",
  "description": "AWS CDK infrastructure for StackAlert — cost spike detection Lambda",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/",
    "README.md"
  ],
  "keywords": [
    "cdk",
    "aws",
    "lambda",
    "cost",
    "monitoring",
    "constructs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stackalertapp/stackalert-cdk.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --require-approval never",
    "destroy": "cdk destroy",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
